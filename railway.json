{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build --workspace=replyjoy-backend && test -f backend/dist/index.js",
    "watchPatterns": [
      "/backend/**",
      "/shared/**",
      "/package.json",
      "/package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start --workspace=replyjoy-backend",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
